# Server Configuration
NODE_ENV=development
PORT=5000

# Database
# Local development
MONGO_URI=mongodb://127.0.0.1:27017/farm_market
# Production (MongoDB Atlas)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/farm-market?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-change-in-production
JWT_EXPIRES_IN=14d

# CORS - Frontend URL(s) - comma separated for multiple origins
# Local development
CLIENT_ORIGIN=http://localhost:5173
# Production (Vercel)
# CLIENT_ORIGIN=https://your-app-name.vercel.app

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (SMTP) - REQUIRED for OTP functionality
# For Gmail: Use App Password (not regular password)
# 1. Enable 2FA on your Gmail account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail"
# 4. Use that 16-character password below (no spaces)
# For other providers: Use their SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com

# Optional: override STARTTLS behavior (default: on for port 587 + SMTP_SECURE=false, e.g. Gmail)
# SMTP_REQUIRE_TLS=true

# Only set to false if your SMTP host uses a self-signed TLS certificate (avoid in production if possible)
# SMTP_TLS_REJECT_UNAUTHORIZED=true
